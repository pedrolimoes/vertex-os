# =============================================================================
# VertexOS — example environment file
# =============================================================================
#
# VertexOS is LOCAL-FIRST and needs NO environment variables to run.
#
#   git clone … && npm install && npm run dev   ← that's the whole setup.
#
# You configure your AI provider and API key INSIDE the app, on the
# "Provider & Keys" page. Those values are stored only in your browser
# (localStorage) — they are never written to disk and never sent to a
# server we control.
#
# This file exists for SELF-HOSTERS who fork VertexOS and want to wire
# their own server-side defaults. The stock app does not read these values.
# Copy it to .env.local (gitignored) if you need it:
#
#   cp .env.example .env.local
#
# 🔒 NEVER commit a real API key.
# -----------------------------------------------------------------------------

# Which provider a fork should default to.
# One of: openrouter | nvidia-nim | deepinfra | gemini | ollama | custom
AI_PROVIDER=

# OpenAI-compatible base URL. Only needed for `custom` or `ollama`
# (e.g. http://localhost:11434/v1). Hosted providers have known defaults.
AI_BASE_URL=

# Your provider API key. DO NOT put a real key here in a committed file.
AI_API_KEY=

# Default model id, e.g.:
#   anthropic/claude-3.5-sonnet   (OpenRouter)
#   meta/llama-3.3-70b-instruct   (NVIDIA NIM)
#   gemini-2.0-flash              (Gemini)
#   llama3.1                      (Ollama)
AI_MODEL=
